# Frontend base URL for the FastAPI backend.
VITE_API_URL=http://localhost:8000

# Public base URL that the API uses when it generates pipeline endpoints.
AGENTMESH_PUBLIC_BASE_URL=http://localhost:8000

# Algorand algod endpoint used for account lookups, balances, and transactions.
ALGOD_ADDRESS=https://testnet-api.algonode.cloud

# Algod API token. Leave empty for providers like AlgoNode that do not require one.
ALGOD_TOKEN=

# Official Algorand x402 facilitator base URL from GoPlausible.
GOPLAUSIBLE_FACILITATOR_URL=https://facilitator.goplausible.xyz

# Internal base URL the backend uses when an agent pays an x402-protected tool route.
AGENTMESH_INTERNAL_API_BASE_URL=http://127.0.0.1:8000

# x402 AVM exact currently settles against Algorand testnet USDC by default.
AGENTMESH_X402_ASSET_ID=10458941

# Tiny ALGO bootstrap used to prep service/API node wallets for USDC opt-in before they receive x402 payments.
AGENTMESH_X402_SERVICE_BOOTSTRAP_ALGO=0.1

# How priced internal tool nodes settle by default: "algo" for native testnet ALGO, "x402" for AVM exact USDC.
AGENTMESH_PAYMENT_MODE=algo

# Local file where deployed pipelines, wallet keys, and run history are persisted.
AGENTMESH_REPOSITORY_PATH=.data/pipelines.json

# Default LLM config for agent reasoning.
AGENTMESH_LLM_PROVIDER=gemini
AGENTMESH_LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
